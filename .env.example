# =====================================================================
# HR Tracker — Environment Variables
# Copy this file to `.env` and fill in real values.
# =====================================================================

# ---- Frontend (Vite) ----
# These are exposed to the browser. Use the *anon* (public) key only.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ---- Backend scripts (Node) ----
# Used by tsx scripts (process:date, rebuild:summaries).
# Use the *service role* key for writes — keep it secret, never ship to the browser.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- Optional ----
# Override the MLB Stats API base URL if you want to point at a mirror.
MLB_API_BASE=https://statsapi.mlb.com/api

# ---- Odds tab (Phase 1) ----
# The Odds API (https://the-odds-api.com) — used by `npm run snapshot:odds`
# and by the cron's MORNING bucket (one snapshot per MLB day, PT 7–11).
#
# Quota math: free tier = 500 reqs/month. Each snapshot ≈ 1 + (games today)
# credits, ~16/day with a full slate. 16 × 30 days = 480/month, fits inside
# the cap with a small cushion. To add midday + pregame later (e.g. on a
# paid tier), see scripts/lib/oddsCron.ts — flip the WINDOWS map.
#
# Without this set, the Odds tab stays empty (the page renders an empty
# state explaining why).
ODDS_API_KEY=your-odds-api-key-here
